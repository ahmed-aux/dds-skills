{
  "name": "dds-skills",
  "version": "0.1.2",
  "description": "CLI to install Claude skills into your projects",
  "type": "module",
  "bin": {
    "dds-skills": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "extractNpmJsxDocs": "npx tsx designSystemUtils/extractJsxDocs.ts ../digital-design-system-react-npm/LII.Bootstrap.npm/src skills/dds-docs/livingston-npm-components",
    "generateAIContext": "node designSystemUtils/generateAIContext.js skills/dds-docs/examples"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "~5.4.0"
  },
  "dependencies": {
    "skills": "^1.5.0"
  }
}
